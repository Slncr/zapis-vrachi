# Локальный запуск (python main.py): укажите localhost.
# Docker Compose ПЕРЕОПРЕДЕЛЯЕТ DATABASE_URL на postgresql://zapis:zapis@postgres:5432/zapis
# — значение ниже нужно только для разработки без Docker.
DATABASE_URL=postgresql://zapis:zapis@127.0.0.1:5432/zapis

# МИС: URL должен открываться ИЗ КОНТЕЙНЕРА api.
# Неверно: http://localhost/... или http://127.0.0.1/... — это сам контейнер, не ваш ПК/сервер.
# Если 1С на той же машине, что и Docker: http://host.docker.internal:ПОРТ/путь (в compose включён host-gateway).
# Иначе: публичный URL или LAN-IP сервера МИС, например http://192.168.1.10/g8_mis
MIS_BASE_URL=http://172.191.7.27/g8_mis #для работы внутри сети компании
MIS_BASE_URL_EXTERNAL=http://185.154.75.166/g8_mis #для работы вне сети компании
MIS_API_KEY=
MIS_USER=
MIS_PASSWORD=
MIS_VERIFY_TLS=true

ENABLE_MAX_BOT=true
MAX_BOT_TOKEN=
MAX_API_BASE_URL=https://platform-api.max.ru
MAX_POLL_TIMEOUT_SEC=30
MAX_POLL_LIMIT=100

SCHEDULE_SYNC_INTERVAL_MINUTES=30
SERVICES_SYNC_INTERVAL_MINUTES=120
# Месяцев расписания вперёд (меньше — меньше нагрузка на МИС).
SCHEDULE_SYNC_MONTHS_AHEAD=2
# Пауза между HTTP к МИС при заливке расписания (сек). 0 — без паузы.
MIS_REQUEST_PAUSE_SEC=0.08
SESSION_TTL_HOURS=24

APP_HOST=0.0.0.0
APP_PORT=8000
